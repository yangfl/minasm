i = 0
.while i < @links
  dBlock = %i
  i += 1

  nCryofluid = dBlock.@cryofluid
  .continue nCryofluid === null

  bEnabled = false
  .do
    .break nCryofluid < 20
    nThorium = dBlock.@thorium
    .break nThorium < 28

    nCapacity = dBlock.@powerNetCapacity
    nStored = dBlock.@powerNetStored
    nRatio = nStored / nCapacity
    .break nRatio > 1

    bEnabled = true
    .if switch1 !== null
      bEnabled = switch1.@enabled
    .fi
  .until

  control enabled dBlock bEnabled
.done
