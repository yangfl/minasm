mUnit = @poly

dBlock = %0
end dBlock === null

nUintFlag = @thisy * @mapw
nUintFlag += @thisx

.while
  bUnitDead = @unit.@dead
  .if bUnitDead == false
    nUnitControlled = @unit.@controlled
    .break nUnitControlled != @ctrlPlayer
  .fi
  ubind mUnit
.done
ucontrol flag nUintFlag
ucontrol boost true

xBlock = dBlock.@x
yBlock = dBlock.@y

ucontrol move xBlock yBlock
ucontrol within xBlock yBlock 2 bWithin
.if bWithin
  ucontrol payEnter
.fi
